# ─── LLM ───
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL_AGENT=claude-sonnet-4-6
ANTHROPIC_MODEL_SCORING=claude-haiku-4-5-20251001

# ─── Embeddings ───
VOYAGE_API_KEY=your-voyage-api-key
EMBEDDING_MODEL=voyage-3

# ─── Vector DB ───
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ─── Prospecting Tools ───
APOLLO_API_KEY=your-apollo-api-key
APIFY_API_TOKEN=your-apify-token

# ─── LinkedIn Automation ───
PHANTOMBUSTER_API_KEY=your-phantombuster-key
LINKEDIN_ACCOUNT_COOKIE=

# ─── Email ───
SENDGRID_API_KEY=your-sendgrid-key
OUTREACH_FROM_EMAIL=outreach@analyticsgear.com
OUTREACH_FROM_NAME=AnalyticsGear

# ─── CRM (Google Sheets) ───
GOOGLE_CREDS_PATH=./credentials.json
CRM_SHEET_ID=your-google-sheet-id

# ─── Phone / Calling ───
JUSTCALL_API_KEY=
JUSTCALL_API_SECRET=

# ─── Monitoring ───
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Runtime ───
ENV=development
LOG_LEVEL=INFO
DRY_RUN=true
